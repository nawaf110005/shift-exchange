# Firebase Client Config (public - safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=shift-exchange-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=shift-exchange-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=shift-exchange-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Firebase Admin SDK (server-side only - NEVER expose publicly)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=shift-exchange-app
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@shift-exchange-app.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
