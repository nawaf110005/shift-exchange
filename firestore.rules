rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // Admin flag lives in Firestore userProfiles/{uid}.isAdmin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function validCode(code) {
      return code.matches('^[0-9]{6}$');
    }
    function validStatus(s) {
      return s in ['in_progress', 'selected', 'confirmed'];
    }

    // ─── /offers ──────────────────────────────────────────────────
    match /offers/{offerId} {
      // READ: in_progress offers are PUBLIC (no sign-in needed to browse)
      //       owner, selector, and admin can read any status
      allow read: if resource.data.status == 'in_progress'
        || isOwner(resource.data.ownerUid)
        || isOwner(resource.data.selectorUid)
        || isAdmin();

      // CREATE: authenticated user with valid data
      allow create: if isAuth()
        && validCode(request.resource.data.ownerCode)
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'in_progress'
        && validStatus(request.resource.data.status)
        && request.resource.data.daysOff.size() > 0
        && request.resource.data.replacementDays.size() <= 16;

