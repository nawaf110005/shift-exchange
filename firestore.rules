          && request.resource.data.ownerUid == resource.data.ownerUid)
        // 2. Selector picks an in_progress offer
        || (isAuth()
          && resource.data.status == 'in_progress'
          && request.auth.uid != resource.data.ownerUid
          && request.resource.data.status == 'selected'
          && request.resource.data.selectorUid == request.auth.uid
          && validCode(request.resource.data.selectorCode)
          && request.resource.data.ownerUid == resource.data.ownerUid)
        // 3. Selector cancels their own selection
        || (isAuth()
          && resource.data.status == 'selected'
          && request.auth.uid == resource.data.selectorUid
          && request.resource.data.status == 'in_progress'
